            "роль_получателя": "lawyer",
            "telegram_chat_id": "={{$json.lawyer_chat_id}}",
            "текст_сообщения": "={{\"Напоминание: событие по делу \" + $json.case_code + \" через 24 часа.\"}}",
            "отправить_в": "={{DateTime.fromISO($json.start_at).minus({hours:24}).toISO()}}",
            "статус": "={{$json.reminder_24h === false ? 'cancelled' : 'pending'}}",
