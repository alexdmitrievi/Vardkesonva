      "parameters": {
        "jsCode": "const raw = $items('Webhook Case Create')[0].json;\nconst body = (raw && typeof raw.body === 'object' && raw.body !== null) ? raw.body : raw;\nconst rows = items.map(i => i.json);\nconst code = String(body.case_code || '').trim();\nconst exists = rows.some(r => String(r['код_дела'] || '').trim() === code);\nreturn [{ ...body, case_code: code, exists }];"
      },
      "name": "CASE_CREATE_AND_FOLDERS :: Check Case Code",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        700,
        300
      ]
