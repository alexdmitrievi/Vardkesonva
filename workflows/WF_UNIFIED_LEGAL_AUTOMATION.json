            {
              "value1": "={{Boolean(($json.client_chat_id && $json.payment_due_at) || $json.reminder_30m === true || Number($json.custom_reminder_minutes || 0) > 0)}}",
              "value2": true
            }
          ]
        }
      },
      "name": "CASE_EVENT_CREATE :: IF Client Payment Reminder",
      "type": "n8n-nodes-base.if",
