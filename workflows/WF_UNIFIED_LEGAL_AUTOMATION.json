        "range": "журнал_отправки_напоминаний!A:D",
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "id_напоминания": "={{$json[\"id_напоминания\"]}}",
            "отправлено_в": "={{$now}}",
            "роль_получателя": "={{$json[\"роль_получателя\"]}}",
            "статус": "sent"
          }
        }
      },
