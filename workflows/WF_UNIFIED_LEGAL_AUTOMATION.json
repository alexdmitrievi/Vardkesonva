            {
              "value1": "={{$env.YC_METADATA_MIRROR === '1' && !!$env.YC_METADATA_API_URL}}",
              "value2": true
            }
          ]
        }
      },
      "name": "CASE_EVENT_CREATE :: IF YC Mirror Enabled",
