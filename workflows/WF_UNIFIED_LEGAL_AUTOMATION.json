          "name": "google_sheets_main"
        }
      }
    },
    {
      "parameters": {
        "operation": "read",
        "sheetId": "={{$env.GSHEET_ID}}",
        "range": "журнал_отправки_напоминаний!A:D"
      },
      "name": "REMINDER_DISPATCH_CRON :: GS Read Sent Log",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4,
      "position": [
        700,
        1920
      ],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "google_sheets_main",
          "name": "google_sheets_main"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const reminders = $items('GS Read Reminders').map(i => i.json);\nconst sentIds = new Set(items.map(i => i.json['id_напоминания']).filter(Boolean));\nconst now = new Date();\nreturn reminders.filter(r => r['статус'] === 'pending' && new Date(r['отправить_в']) <= now && !sentIds.has(r['id_напоминания'])).map(r => ({ json: r }));"
      },
      "name": "REMINDER_DISPATCH_CRON :: Filter Due",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        940,
        1920
      ]
    },
    {
      "parameters": {
        "batchSize": 1
      },
      "name": "REMINDER_DISPATCH_CRON :: Split",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [
        1160,
        1920
      ]
    },
    {
      "parameters": {
        "chatId": "={{$json['telegram_chat_id']}}",
        "text": "={{$json['текст_сообщения'] || ($json['роль_получателя'] === 'client' ? 'Напоминание по вашему делу.' : 'Напоминание по событию.')}}"
      },
      "name": "REMINDER_DISPATCH_CRON :: TG Send",
