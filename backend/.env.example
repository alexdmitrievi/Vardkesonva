APP_NAME=legal-automation-backend
APP_ENV=development
API_PREFIX=/api/v1

N8N_BASE_URL=http://localhost:5678
N8N_TIMEOUT_SECONDS=30
N8N_CASE_CREATE_PATH=/webhook/case/create
N8N_EVENT_CREATE_PATH=/webhook/case/event/create
N8N_AI_CONSULT_PATH=/webhook/ai/legal/consult

REQUIRE_AUTH=false
API_BEARER_TOKEN=change_me_for_production
CORS_ORIGINS=http://localhost:8080,http://localhost:3000

MAX_UPLOAD_SIZE_MB=25
ALLOWED_FILE_EXTENSIONS=jpg,jpeg,png,pdf,doc,docx,txt
STORAGE_ROOT=storage
INDEX_FILE_NAME=index.json
